@inject GitService GitService
@inject AppState AppState

<div class="flex flex-col h-full bg-surface-container-low p-4 overflow-hidden">
    @if (Repo is not null)
    {
        <div class="bg-surface-container-lowest rounded-md p-3 flex flex-col gap-2">
            <input class="bg-transparent border-none focus:ring-0 text-sm font-mono text-primary placeholder:text-on-surface-variant/30 w-full outline-none"
                   placeholder="Commit subject"
                   @bind="Repo.CommitSubject"
                   @bind:event="oninput" />
            <textarea class="bg-transparent border-none focus:ring-0 text-xs font-mono text-on-surface-variant placeholder:text-on-surface-variant/30 w-full h-16 resize-none outline-none"
                      placeholder="Description (optional)"
                      @bind="Repo.CommitDescription"
                      @bind:event="oninput"></textarea>
        </div>

        <div class="flex justify-between items-center mt-3">
            <div class="flex gap-2">
                <span class="material-symbols-outlined text-on-surface-variant hover:text-primary cursor-pointer">alternate_email</span>
                <span class="material-symbols-outlined text-on-surface-variant hover:text-primary cursor-pointer">tag</span>
            </div>
            <button class="bg-gradient-to-br from-primary to-primary-container text-on-primary px-4 py-1.5 rounded-md font-bold text-xs uppercase tracking-widest hover:brightness-110 active:scale-95 transition-all disabled:opacity-40"
                    disabled="@(string.IsNullOrWhiteSpace(Repo.CommitSubject) || _committing)"
                    @onclick="Commit">
                @if (_committing)
                {
                    <span>Committing...</span>
                }
                else
                {
                    <span>Commit to @(Repo.Branch ?? "main")</span>
                }
            </button>
        </div>
    }
    else
    {
        <div class="flex-1 flex items-center justify-center text-on-surface-variant/30 text-xs italic">
            No repository selected
        </div>
    }
</div>

@code {
    [Parameter] public RepoContext? Repo { get; set; }
    [Parameter] public EventCallback OnCommit { get; set; }

    private bool _committing;

    private async Task Commit()
    {
        if (Repo is null || string.IsNullOrWhiteSpace(Repo.CommitSubject)) return;

        _committing = true;
        try
        {
            await GitService.CommitAsync(Repo.WslDistro, Repo.WslPath, Repo.CommitSubject, Repo.CommitDescription, amend: false);
            Repo.CommitSubject = "";
            Repo.CommitDescription = "";
            await OnCommit.InvokeAsync();
        }
        finally
        {
            _committing = false;
        }
    }
}
